@model SportShop.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="row">
    <div class="col-md-6">
        <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Name" onerror="this.src='/images/placeholder.jpg'">
    </div>
    <div class="col-md-6">
        <h1>@Model.Name</h1>
        <p class="badge bg-secondary">@Model.Category</p>
        <h3 class="text-primary mt-3">@Model.Price.ToString("C")</h3>
        <p class="mt-4">@Model.Description</p>
        <p class="fw-bold">В наличии: @Model.StockQuantity шт.</p>

        <!-- ФОРМА ДОБАВЛЕНИЯ В КОРЗИНУ -->
        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-3">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="row g-2 align-items-center">
                <div class="col-auto">
                    <label for="quantity" class="col-form-label">Количество:</label>
                </div>
                <div class="col-auto">
                    <input type="number" name="quantity" value="1" min="1" class="form-control" style="width: 80px;" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-lg btn-success">🛒 Добавить в корзину</button>
                </div>
            </div>
        </form>

        <a href="/" class="btn btn-lg btn-outline-secondary mt-3 ms-2">← Назад к каталогу</a>
    </div>
</div>